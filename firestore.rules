rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ── Helpers ─────────────────────────────────────
    function isAuthenticated() { return request.auth != null; }

    // Support both Custom Claims (fast, approved) and Doc fallback (instant for bootstrap and registration)s
    function isSuperAdmin() { 
      return isAuthenticated() && (
        request.auth.token.role == 'superadmin' || 
        request.auth.token.email == 'brgytanodsos@gmail.com' ||
        request.auth.token.email == 'admin@mindorotransit.com' ||
        request.auth.token.email == 'admin_new@mindorotransit.com' ||
        (exists(/databases/{database}/documents/adminAccounts/$(request.auth.uid)) && 
         get(/databases/{database}/documents/adminAccounts/$(request.auth.uid)).data.role == 'superadmin')
      ); 
    }
    
    function isPortAdmin() { 
      return isAuthenticated() && (
        request.auth.token.role == 'port' || 
        request.auth.token.email == 'port@mindorotransit.com' ||
        (exists(/databases/{database}/documents/adminAccounts/$(request.auth.uid)) && 
         get(/databases/{database}/documents/adminAccounts/$(request.auth.uid)).data.role == 'port')
      ); 
    }
    
    function isTerminalAdmin() { 
      return isAuthenticated() && (
        request.auth.token.role == 'terminal' || 
        request.auth.token.email == 'terminal@mindorotransit.com' ||
        (exists(/databases/{database}/documents/adminAccounts/$(request.auth.uid)) && 
         get(/databases/{database}/documents/adminAccounts/$(request.auth.uid)).data.role == 'terminal')
      ); 
    }
    
    function isStaffOrAdmin() { return isPortAdmin() || isTerminalAdmin() || isSuperAdmin(); }
    function isOwner(uid) { return request.auth.uid == uid; }

    function isValidTimestamp() {
      return !('syncedAt' in request.resource.data) || (
        request.resource.data.syncedAt is timestamp &&
        request.resource.data.syncedAt == request.time
      );
    }

    // ── Core Collections ────────────────────────────
    match /ships/{shipId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin() || isPortAdmin();
      
      match /priceHistory/{historyId} {
        allow read: if isAuthenticated();
        allow write: if isStaffOrAdmin();
      }
    }

    match /trips/{tripId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin() || isTerminalAdmin();
      
      match /priceHistory/{historyId} {
        allow read: if isAuthenticated();
        allow write: if isStaffOrAdmin();
      }
    }

    match /priceAdjustmentRequests/{requestId} {
      allow read, write: if isStaffOrAdmin();
    }

    match /payouts/{payoutId} {
      allow read, write: if isStaffOrAdmin();
    }

    match /ferryBookings/{bookingId} {
      allow read: if isOwner(resource.data.accountId) || isStaffOrAdmin();
      allow create: if isAuthenticated() && isValidTimestamp();
      allow update: if (isOwner(resource.data.accountId) || isStaffOrAdmin()) && isValidTimestamp();
      allow delete: if isSuperAdmin();
    }

    match /vanBookings/{bookingId} {
      allow read: if isOwner(resource.data.accountId) || isStaffOrAdmin();
      allow create: if isAuthenticated() && isValidTimestamp();
      allow update: if (isOwner(resource.data.accountId) || isStaffOrAdmin()) && isValidTimestamp();
      allow delete: if isSuperAdmin();
    }

    match /userAccounts/{userId} {
      allow read: if isOwner(userId) || isStaffOrAdmin();
      allow write: if isOwner(userId) || isSuperAdmin();
    }

    // Admin & Financial - stricter
    match /adminAccounts/{adminId} {
      allow read, write: if isOwner(adminId) || isSuperAdmin();
    }

    match /transactions/{txId} {
      allow read:   if isStaffOrAdmin();
      allow create: if isStaffOrAdmin();
      allow update: if isSuperAdmin(); // Only super admin can modify a completed tx
      allow delete: if false;          // Transactions are immutable; never delete
    }

    match /payoutHistory/{recordId} {
      allow read, write: if isStaffOrAdmin();
    }

    match /auditLog/{logId} {
      allow create: if isAuthenticated();
      allow read: if isStaffOrAdmin();
    }

    // Weather & Announcements - read-heavy, offline friendly
    match /announcements/{annId} {
      allow read: if isAuthenticated();
      allow write: if isStaffOrAdmin();
    }

    match /weatherAlerts/{alertId} {
      allow read: if isAuthenticated();
    }

    // ── Offline Queue (server-managed only) ───────────────────────────────────
    match /offlineQueue/{queueId} {
      allow read, write: if isSuperAdmin();
    }

    // ── Catch-all ───────────────────────────────────
    match /{document=**} {
      allow read, write: if false; // Explicit deny
    }
  }
}
