rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isSuperAdmin() {
      return request.auth != null && request.auth.token.role == 'superadmin';
    }
    
    function isPortAdmin() {
      return request.auth != null && request.auth.token.role == 'port';
    }
    
    function isTerminalAdmin() {
      return request.auth != null && request.auth.token.role == 'terminal';
    }

    // Ships & Trips - Read for all authenticated, Write for admins
    match /ships/{shipId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isPortAdmin() || isSuperAdmin();
    }
    
    match /trips/{tripId} {
      allow read: if isAuthenticated();
      allow write: if isTerminalAdmin() || isSuperAdmin();
    }

    // Bookings - Critical protection
    match /ferryBookings/{bookingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isPortAdmin() || isSuperAdmin() || 
        (resource.data.accountId == request.auth.uid);
    }

    match /vanBookings/{bookingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isTerminalAdmin() || isSuperAdmin() || 
        (resource.data.accountId == request.auth.uid);
    }

    // Transactions (Financial) - Strict control
    match /transactions/{txId} {
      allow read: if isPortAdmin() || isTerminalAdmin() || isSuperAdmin();
      allow create: if isPortAdmin() || isTerminalAdmin() || isSuperAdmin();
      allow update: if isSuperAdmin(); // Only super admin can modify completed tx
    }

    // Announcements & Public Data
    match /announcements/{annId} {
      allow read: if true;  // Public
      allow write: if isPortAdmin() || isSuperAdmin();
    }

    // User Accounts
    match /userAccounts/{userId} {
      allow read, write: if request.auth.uid == userId || isSuperAdmin();
    }

    // Audit Logs - Write-only for admins
    match /auditLogs/{logId} {
      allow read: if isSuperAdmin();
      allow create: if isAuthenticated();
    }

    // Offline Queue (if you store it in Firestore)
    match /offlineQueue/{queueId} {
      allow read, write: if isSuperAdmin();
    }
  }
}
