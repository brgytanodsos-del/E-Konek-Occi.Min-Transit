{
  "entities": {
    "Vessel": {
      "title": "Vessel",
      "description": "Ferry or ship information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "route": { "type": "string" },
        "depTime": { "type": "string" },
        "arrTime": { "type": "string" },
        "status": { "type": "string" },
        "capacity": { "type": "number" },
        "available": { "type": "number" },
        "type": { "type": "string" }
      }
    },
    "Trip": {
      "title": "Trip",
      "description": "Van or bus trip information",
      "type": "object",
      "properties": {
        "route": { "type": "string" },
        "depTime": { "type": "string" },
        "type": { "type": "string" },
        "driver": { "type": "string" },
        "capacity": { "type": "number" },
        "available": { "type": "number" },
        "status": { "type": "string" }
      }
    },
    "Booking": {
      "title": "Booking",
      "description": "User booking information",
      "type": "object",
      "properties": {
        "serviceId": { "type": "string", "description": "Ferry or Trip ID" },
        "customerName": { "type": "string" },
        "contact": { "type": "string" },
        "seats": { "type": "number" },
        "status": { "type": "string" },
        "pickup": { "type": "string" },
        "type": { "type": "string" }
      }
    },
    "Announcement": {
      "title": "Announcement",
      "description": "System announcements",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "date": { "type": "string" },
        "author": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/vessels/{vesselId}": {
      "schema": { "$ref": "#/entities/Vessel" },
      "description": "All ferry and ship vessels"
    },
    "/trips/{tripId}": {
      "schema": { "$ref": "#/entities/Trip" },
      "description": "All land transport trips"
    },
    "/bookings/{bookingId}": {
      "schema": { "$ref": "#/entities/Booking" },
      "description": "All user bookings"
    },
    "/announcements/{announcementId}": {
      "schema": { "$ref": "#/entities/Announcement" },
      "description": "Announcements visible to users"
    }
  }
}
